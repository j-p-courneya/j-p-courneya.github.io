---
import '../styles/global.css';

const profile = {
  name: 'Jean-Paul Courneya',
  displayName: 'J-P Courneya',
  email: 'jean-paul.courneya@som.umaryland.edu',
  jobTitle: 'Lead Bioinformatics Analyst',
  institution: 'Center for Vaccine Development',
  university: 'University of Maryland, Baltimore',
  bio: `I build and maintain multi-omics pipelines — spanning genomics, proteomics, and single-cell and spatial transcriptomics — at the University of Maryland Baltimore Center for Vaccine Development. My work spans HPC infrastructure, reproducible workflow design, and large-scale biological data analysis, supporting faculty, postdocs, and graduate researchers across vaccine and rare disease research.`,
  links: [
    {
      label: 'Email',
      href: 'mailto:jean-paul.courneya@som.umaryland.edu',
      icon: 'email',
    },
    {
      label: 'GitHub',
      href: 'https://github.com/j-p-courneya',
      icon: 'github',
    },
    {
      label: 'Scholar',
      href: 'https://share.google/SJgdEvhAVGnKd6ZpD',
      icon: 'scholar',
    },
    {
      label: 'ORCID',
      href: 'https://orcid.org/0000-0001-9014-649X',
      icon: 'orcid',
    },
    {
      label: 'LinkedIn',
      href: 'https://www.linkedin.com/in/jean-paul-courneya-65721715',
      icon: 'linkedin',
    },
  ],
};
---

<!DOCTYPE html>
<html lang="en-US">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{profile.displayName}</title>
    <meta name="description" content={`${profile.displayName} — ${profile.jobTitle}, ${profile.university}`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;600&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
  </head>
  <body>
    <canvas id="stars"></canvas>
    <main>
      <div class="content">

        <!-- Avatar -->
        <div class="avatar" aria-hidden="true">
          <img
            src={`https://avatars.githubusercontent.com/u/11720131?v=4`}
            alt=""
            class="avatar-img"
            onerror="this.remove()"
          />
          <span class="avatar-initials">JPC</span>
        </div>

        <!-- Identity -->
        <p class="eyebrow">{profile.jobTitle}</p>
        <h1>{profile.displayName}</h1>
        <p class="institution">{profile.institution} · {profile.university}</p>

        <div class="divider"></div>

        <!-- Bio -->
        <p class="bio">{profile.bio}</p>

        <!-- Links -->
        <nav class="actions" aria-label="Profile links">
          {profile.links.map((link) => (
            <a
              href={link.href}
              class="btn"
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
            >
              <span class="btn-icon" aria-hidden="true">
                {link.icon === 'email' && (
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                )}
                {link.icon === 'github' && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
                )}
                {link.icon === 'scholar' && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 3L1 9l11 6 9-4.91V17h2V9L12 3zM5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82z"/></svg>
                )}
                {link.icon === 'orcid' && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.372 0 0 5.372 0 12s5.372 12 12 12 12-5.372 12-12S18.628 0 12 0zM7.369 4.378c.525 0 .947.431.947.947s-.422.947-.947.947a.95.95 0 01-.947-.947c0-.525.422-.947.947-.947zm-.722 3.038h1.444v10.041H6.647V7.416zm3.562 0h3.9c3.712 0 5.344 2.653 5.344 5.025 0 2.578-2.016 5.016-5.325 5.016h-3.919V7.416zm1.444 1.303v7.434h2.297c3.272 0 3.872-2.412 3.872-3.722 0-2.016-1.284-3.712-3.862-3.712h-2.307z"/></svg>
                )}
                {link.icon === 'linkedin' && (
                  <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                )}
              </span>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </main>

    <script>
      const canvas = document.getElementById('stars') as HTMLCanvasElement;
      const ctx = canvas.getContext('2d')!;
      let stars: { x: number; y: number; r: number; o: number; speed: number }[] = [];

      function resize() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
      }

      function initStars() {
        stars = Array.from({ length: 220 }, () => ({
          x: Math.random() * canvas.width,
          y: Math.random() * canvas.height,
          r: Math.random() * 1.5 + 0.2,
          o: Math.random(),
          speed: Math.random() * 0.004 + 0.001,
        }));
      }

      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        const t = Date.now() / 1000;
        for (const s of stars) {
          const opacity = 0.3 + 0.7 * (0.5 + 0.5 * Math.sin(t * s.speed * 60 + s.o * 100));
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.r, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(255,255,255,${opacity})`;
          ctx.fill();
        }
        requestAnimationFrame(draw);
      }

      resize();
      initStars();
      draw();
      window.addEventListener('resize', () => { resize(); initStars(); });
    </script>
  </body>
</html>
